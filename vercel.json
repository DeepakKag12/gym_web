{
  "version": 2,
  "buildCommand": "cd frontend && npm install --legacy-peer-deps && CI=false npm run build",
  "outputDirectory": "frontend/build",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "build": {
    "env": {
      "REACT_APP_API_URL": "https://g-ym-backend.vercel.app/api"
    }
  }
}
