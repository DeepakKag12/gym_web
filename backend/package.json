{
  "name": "fitnessbyajeet-backend",
  "version": "1.0.0",
  "description": "Backend for FitnessByAjeet Gym Management System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node -e \"const {execSync}=require('child_process');try{const p=execSync('netstat -ano').toString().split('\\n').find(l=>l.includes(':5000')&&l.includes('LISTENING'));if(p){const pid=p.trim().split(/\\s+/).pop();execSync('taskkill /PID '+pid+' /F');console.log('Freed port 5000')}}catch(e){}\" && nodemon server.js",
    "seed": "node seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-fileupload": "^1.5.1",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "twilio": "^5.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  }
}
